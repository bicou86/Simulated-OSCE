        {
          "id": "m3",
          "text": "Critères diagnostiques du syndrome néphrotique",
          "details": [
            "Protéinurie > 3 g/24h (ou > 3 g/g de créatinine)",
            "Hypoalbuminémie < 30 g/L",
            "Œdèmes cliniques",
            "Hyperlipidémie (souvent associée)"
          ],
          "scoringRule": "Syndrome néphrotique = protéinurie > 3g/24h + hypoalbuminémie < 30g/L"
        },
        {
          "id": "m4",
          "text": "Bilan étiologique du syndrome néphrotique",
          "details": [
            "Sédiment urinaire (cylindres, hématies dysmorphiques)",
            "Électrophorèse des protéines sériques et urinaires",
            "Complément C3, C4",
            "Anticorps anti-nucléaires (AAN) si suspicion lupus",
            "Sérologies virales (VHB, VHC, VIH)",
            "Glycémie à jeun (diabète)",
            "Échographie rénale et des voies urinaires"
          ]
