        {
          "id": "m5",
          "text": "Traitement symptomatique du syndrome néphrotique",
          "therapySection": {
            "categories": [
              {
                "title": "Mesures générales",
                "content": "• Restriction sodée < 6g/j (< 2g de sodium)\n• Restriction hydrique si hyponatrémie\n• Repos avec surélévation des membres inférieurs\n• Bas de contention\n• Pesée quotidienne\n• Surveillance diurèse"
              },
              {
                "title": "Traitement diurétique",
                "content": "• Furosémide 40-80mg/j per os ou IV\n• Association possible avec thiazidique si résistance\n• Surveillance ionogramme, fonction rénale\n• Objectif: perte 0.5-1 kg/jour\n• Éviter hypovolémie brutale"
              },
              {
                "title": "Prévention des complications",
                "content": "• Anticoagulation si albumine < 20g/L (risque thrombotique)\n• Statine si hyperlipidémie sévère\n• Supplémentation vitamine D\n• Vaccination pneumocoque (risque infectieux)\n• IEC/ARA2 pour effet antiprotéinurique"
              },
              {
                "title": "Traitement étiologique",
                "content": "• Corticothérapie si glomérulonéphrite à lésions minimes\n• Immunosuppresseurs selon type histologique\n• Traitement spécifique si cause secondaire\n• Biopsie rénale pour déterminer le traitement"
              }
            ]
          }
        },
