    "resume": {
      "titre": "🦶 Tendinopathie d’insertion du tendon d’Achille – Résumé ECOS",
      "sections": [
        {
          "titre": "🔍 Anamnèse",
          "subsections": [
            {
              "titre": "Symptômes principaux",
              "points": [
                "Douleur postérieure du talon, au point d’insertion du tendon sur le calcanéus",
                "Douleur à l’effort, surtout lors de la marche ou de la course",
                "Douleur matinale ou après une période de repos (raideur au premier pas)",
                "Évolution chronique, par poussées"
              ]
            },
            {
              "titre": "Contexte et facteurs de risque",
              "points": [
                "Sportifs (course à pied, sports avec sauts/répétition de poussée sur l’avant-pied)",
                "Surmenage ou augmentation brutale de l’activité physique",
                "Chaussures inadaptées (rigides au talon, talons plats)",
                "Troubles statiques du pied (pied creux, pied plat)",
                "Âge > 40 ans (dégénérescence tendineuse)",
                "Surpoids"
              ]
            }
          ]
        },
