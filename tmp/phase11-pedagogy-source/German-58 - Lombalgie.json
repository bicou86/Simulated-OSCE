          "titre": "👀 Examen clinique",
          "subsections": [
            {
              "titre": "Tests cliniques",
              "points": [
                "Lasègue (straight leg raise) positif : douleur irradiant dans le territoire radiculaire",
                "Bragard : reproduction douleur à dorsiflexion pied après Lasègue",
                "Crossed Lasègue : douleur controlatérale (spécifique)"
              ]
            },
            {
              "titre": "Atteintes radiculaires typiques",
              "points": [
                "L4 : déficit extension genou, hypoesthésie face antéro-médiale jambe, ROT rotulien ↓",
                "L5 : déficit dorsiflexion pied (steppage), hypoesthésie dos pied/gros orteil",
                "S1 : déficit flexion plantaire, hypoesthésie bord externe pied, ROT achilléen ↓"
              ]
            }
          ]
        },
        {
          "titre": "🧪 Examens diagnostiques",
          "subsections": [
            {
              "titre": "Imagerie",
              "points": [
                "IRM lombaire : examen de référence, visualise hernie, compression radiculaire",
                "Scanner lombaire si IRM contre-indiquée"
              ]
            },
            {
              "titre": "Autres",
              "points": [
                "EMG utile pour différencier neuropathie périphérique vs radiculopathie",
                "Pas d’imagerie systématique si absence de red flags"
              ]
            }
          ]
        },
