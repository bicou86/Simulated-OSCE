                "Correction des postures et exercices d’assouplissement"
              ]
            },
            {
              "titre": "Collier cervical",
              "points": [
                "Pas recommandé systématiquement",
                "Si utilisé : uniquement en phase aiguë pour quelques jours (but antalgique)"
              ]
            }
          ]
        },
